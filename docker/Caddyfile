# Caddy reverse proxy. The site address is env-driven so the same file works
# in both deployment phases (SITE_ADDRESS comes from docker-compose → VPS .env):
#   SITE_ADDRESS=:80              → plain HTTP on port 80 (serving on a bare IP;
#                                   Let's Encrypt cannot issue a cert for a bare IP)
#   SITE_ADDRESS=app.example.com  → automatic HTTPS via Let's Encrypt (once DNS
#                                   points a real domain at this VPS)

{$SITE_ADDRESS:localhost} {
	encode gzip zstd
	reverse_proxy web:3000
}

# Copy to `.env` in the same directory as docker-compose.yml ON THE VPS.
# docker compose reads this file automatically. Contains NO secrets — just the
# public site address and the GHCR owner used to pull the image.
# The deploy workflow overwrites docker-compose.yml and Caddyfile on each run
# but never touches this .env, so server-specific values here persist.

# Caddy site address — controls HTTP vs HTTPS:
#   :80                → plain HTTP on port 80. Use while serving on a bare IP
#                        (Let's Encrypt cannot issue a certificate for a bare IP).
#   app.example.com    → automatic HTTPS via Let's Encrypt. Use once a domain's
#                        DNS A/AAAA record points at this VPS.
SITE_ADDRESS=:80

# Public URL the app advertises (feeds NEXT_PUBLIC_APP_URL). Keep it in step
# with SITE_ADDRESS:
#   http://<vps-ip>           while on a bare IP
#   https://app.example.com   once a domain + HTTPS are live
APP_URL=http://187.127.178.219

# GitHub owner/org that hosts the ghcr.io/<owner>/wedevs-web image.
GHCR_OWNER=rajin10

# Optional: overrides the /api/health sha reported by this deployment.
GIT_SHA=prod

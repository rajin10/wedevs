# Copy to `.env` in the same directory as docker-compose.yml ON THE VPS.
# docker compose reads this automatically. Contains NO secrets — just the
# public domain and the GHCR owner used to pull the image.

# The domain that points (DNS A/AAAA record) at this VPS. Caddy issues TLS for it.
DOMAIN=app.example.com

# GitHub owner/org that hosts the ghcr.io/<owner>/wedevs-web image.
GHCR_OWNER=rajin10

# Optional: overrides the /api/health sha for this deployment.
GIT_SHA=prod

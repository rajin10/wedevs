# Wedevs web — environment example.
# Copy to .env.local for local dev. All auth vars are OPTIONAL: with none set,
# the app runs in demo-session mode. Set BOTH public Supabase vars to switch to
# real auth (Email magic-link + Google + GitHub). See ../../supabase/README.md.

# Public app URL (used for OAuth redirect origins, links). Defaults to localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — set BOTH to switch auth from demo mode to real Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (secret) — needed to apply the profiles trigger / admin tasks.
# Never commit a real value; never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
